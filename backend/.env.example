# ---- Required ----
PORT=3000
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:4200

# ---- Optional: durable storage ----
# With no database set, the app uses an in-memory store seeded with sample data
# (great for local dev / Teams preview; data resets on restart).
# Set a Postgres connection string to persist data. On Vercel, creating a Postgres
# store in the project's Storage tab injects POSTGRES_URL automatically.
# POSTGRES_URL=postgres://user:password@host/dbname

# ---- Optional: AI gateway (moderation + assistant) ----
# When all three are set, recognitions are screened by the AI model (in addition
# to the built-in keyword check) and the in-app assistant is enabled. Without
# them the app still works: keyword moderation only, assistant disabled.
# ANTHROPIC_API_KEY=sk-...
# ANTHROPIC_BASE_URL=https://your-gateway-host:port
# ANTHROPIC_MODEL=Qwen3.5-122b

# Set to 'false' to disable AI moderation while keeping the assistant enabled.
# AI_MODERATION=true
