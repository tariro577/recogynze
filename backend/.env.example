# ---- Required ----
PORT=3000
CORS_ORIGIN=http://localhost:4200
RECOGNYZE_SITE_ID=YOUR_SITE_ID
RECOGNYZE_RECOGNITIONS_LIST_ID=YOUR_RECOGNITIONS_LIST_ID

# ---- Optional lists ----
# Leave these unset to run with ONLY the Recognitions list.
#  - No Badges list   -> the six built-in badges are used.
#  - No Reactions list -> the 👏🏆❤️ reaction buttons are disabled.
# RECOGNYZE_BADGES_LIST_ID=YOUR_BADGES_LIST_ID
# RECOGNYZE_REACTIONS_LIST_ID=YOUR_REACTIONS_LIST_ID

# ---- Trust boundary (optional) ----
# Set ALL THREE to enable On-Behalf-Of mode: the backend validates the incoming
# API token and exchanges it for a Graph token. Leave them unset to run in
# passthrough mode (the caller's Graph token is forwarded directly).
# AAD_TENANT_ID=YOUR_TENANT_ID
# AAD_CLIENT_ID=YOUR_BACKEND_APP_CLIENT_ID
# AAD_CLIENT_SECRET=YOUR_BACKEND_APP_CLIENT_SECRET
# Optional: comma-separated accepted audiences (defaults to the client id + api://<client id>)
# AAD_API_AUDIENCE=api://YOUR_BACKEND_APP_CLIENT_ID
